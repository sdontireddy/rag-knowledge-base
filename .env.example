# Ollama
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=tinyllama:latest
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
CHROMADB_IMAGE_TAG=0.5.5
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_knowledge_base

# Ingestion
SOURCE_DIRS=AWS,LULU,Techno,MyDocuments
KNOWLEDGE_BASE_ROOT=/app/knowledge_base
INGESTION_REPORT_PATH=/tmp/ingestion_report.json
HOST_INGESTION_REPORT_PATH=./reports/ingestion_report.json
INGESTION_MIN_FILE_DELTA_SECONDS=0

# Chunking
MAX_CHUNK_TOKENS=1000
MIN_CHUNK_TOKENS=100

# Search
DEFAULT_K=5
MIN_RELEVANCE_SCORE=0.0

# Answer Generation
MAX_ANSWER_TOKENS=1024
ANSWER_TIMEOUT_SECONDS=180

# API
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO

# UI
API_BASE_URL=http://api:8080
UI_ANSWER_TIMEOUT_SECONDS=90
